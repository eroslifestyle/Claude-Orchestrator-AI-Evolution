{
  "name": "orchestrator-plugin",
  "version": "6.0.0",
  "description": "Intelligent multi-agent orchestration plugin for Claude Code with parallel execution, context management, and error recovery",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": {
    "name": "Eros Lifestyle",
    "email": "dev@eroslifestyle.com"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "plugin",
    "orchestration",
    "ai-agents",
    "automation",
    "multi-agent",
    "task-management",
    "parallel-execution",
    "error-recovery",
    "token-budget"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/eroslifestyle/Claude-Orchestrator-Plugin.git"
  },
  "engines": {
    "node": ">=18.0.0",
    "claude-code": ">=2.0.0"
  },
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "build:watch": "tsc --watch",
    "copy-assets": "shx mkdir -p dist/config && shx mkdir -p dist/templates && shx cp -r config/* dist/config/ && shx cp -r templates/* dist/templates/",
    "clean": "rimraf dist/",
    "dev": "npm run clean && npm run build:watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "npm run build && node dist/tests/e2e-tests.js",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write src/**/*.{ts,tsx,json,md}",
    "format:check": "prettier --check src/**/*.{ts,tsx,json,md}",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run test",
    "package": "npm run clean && npm run build && npm run create-plugin-package",
    "create-plugin-package": "ts-node scripts/plugin-installer.ts package",
    "install-plugin": "npm run package && ts-node scripts/plugin-installer.ts install --force",
    "uninstall-plugin": "ts-node scripts/plugin-installer.ts uninstall",
    "validate-plugin": "ts-node scripts/plugin-installer.ts validate",
    "setup-wizard": "ts-node src/ui/setup-wizard-cli.ts",
    "benchmark": "node dist/benchmarks/performance-test.js",
    "docs:generate": "typedoc src/ --out docs/api/",
    "docs:auto": "node dist/documentation/auto-generate-docs.js",
    "release": "npm run validate && npm run test:e2e && npm run package && npm run docs:generate",
    "start": "node dist/index.js",
    "debug": "node --inspect-brk dist/index.js",
    "cli": "ts-node src/ui/CLIInterface.ts",
    "postinstall": "npm run build",
    "setup": "ts-node scripts/setup.ts",
    "verify": "ts-node scripts/verify.ts",
    "stress-test": "ts-node src/run-integrated-stress-test.ts",
    "stress-test:full": "ts-node src/run-integrated-stress-test.ts --tasks 100 --agents 64"
  },
  "dependencies": {
    "@types/node": "^20.0.0",
    "natural": "^6.8.0",
    "ajv": "^8.12.0",
    "yaml": "^2.3.0",
    "commander": "^11.0.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.0",
    "table": "^6.8.0",
    "progress": "^2.0.3",
    "uuid": "^9.0.0",
    "lodash": "^4.17.21",
    "fast-glob": "^3.3.0",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "shx": "^0.3.4",
    "typescript": "^5.2.0",
    "@types/natural": "^5.1.0",
    "@types/uuid": "^9.0.0",
    "@types/lodash": "^4.14.0",
    "@types/progress": "^2.0.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "typedoc": "^0.25.0",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.20.0"
  },
  "files": [
    "dist/",
    "config/",
    "templates/",
    "scripts/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "plugin-manifest.json"
  ],
  "bin": {
    "orchestrator-install": "./scripts/plugin-installer.js",
    "orchestrator-cli": "./dist/ui/CLIInterface.js"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src", "<rootDir>/tests"],
    "testMatch": [
      "**/__tests__/**/*.+(ts|tsx|js)",
      "**/*.(test|spec).+(ts|tsx|js)"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/*.test.{ts,tsx}",
      "!src/benchmarks/**/*"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "eslintConfig": {
    "parser": "@typescript-eslint/parser",
    "extends": [
      "eslint:recommended",
      "@typescript-eslint/recommended"
    ],
    "plugins": [
      "@typescript-eslint"
    ],
    "rules": {
      "@typescript-eslint/no-unused-vars": "error",
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/explicit-function-return-type": "warn",
      "prefer-const": "error",
      "no-var": "error"
    },
    "env": {
      "node": true,
      "jest": true,
      "es2022": true
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false
  }
}