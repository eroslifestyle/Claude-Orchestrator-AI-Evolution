{
  "version": "6.0.0",
  "name": "orchestrator-ultra",
  "description": "Configurazione v4.0 con esecuzione parallela, context management e error recovery",

  "parallel": {
    "maxConcurrentAgents": 64,
    "enableAggressiveParallel": true,
    "respectOnlyHardDependencies": true,
    "minBatchSize": 1,
    "maxBatchWaitMs": 5000,
    "description": "REGOLA 1: Esegui N task senza dipendenze simultaneamente con N agent"
  },

  "context": {
    "clearBeforeEachExecution": true,
    "maxTokensBeforeAutoClear": 50000,
    "preserveSystemPrompt": true,
    "preserveLastNTurns": 0,
    "periodicCleanupIntervalMs": 60000,
    "description": "REGOLA 2: Clear contesto prima di OGNI esecuzione agent"
  },

  "tokenBudget": {
    "maxTokensPerConversation": 200000,
    "greenThresholdPercent": 50,
    "yellowThresholdPercent": 70,
    "redThresholdPercent": 85,
    "criticalThresholdPercent": 95,
    "autoDecomposeOnRed": true,
    "autoClearOnCritical": true,
    "description": "REGOLA 5: Mantenere utilizzo token sotto 50-70%"
  },

  "recovery": {
    "maxRetries": 3,
    "retryDelayMs": 1000,
    "retryBackoffMultiplier": 2,
    "maxRetryDelayMs": 30000,
    "enableAutoEscalation": true,
    "escalationThreshold": 2,
    "circuitBreakerThreshold": 5,
    "circuitBreakerResetMs": 60000,
    "description": "REGOLA 4: Retry -> Escalation -> Fallback per 100% success rate"
  },

  "visualization": {
    "enabled": true,
    "showTimestamps": true,
    "showAgentActivity": true,
    "showTaskProgress": true,
    "showPerformanceMetrics": true,
    "showContextEvents": true,
    "showDependencyFlow": true,
    "showErrors": true,
    "colorOutput": true,
    "minLogLevel": "INFO",
    "description": "REGOLA 3: Visualizza TUTTI i messaggi durante esecuzione"
  },

  "models": {
    "default": "sonnet",
    "fallbackOrder": ["haiku", "sonnet", "opus"],
    "costMultipliers": {
      "haiku": 1,
      "sonnet": 5,
      "opus": 25
    }
  },

  "agents": {
    "fallbackMap": {
      "gui-expert": "general-coder",
      "database-expert": "general-coder",
      "security-expert": "general-coder",
      "api-expert": "integration-expert"
    }
  },

  "hierarchy_rules": {
    "enabled": true,
    "levels": {
      "L0_core": {
        "priority": 1,
        "can_spawn": ["L1_expert", "L2_subagent"],
        "agents": ["orchestrator", "analyzer", "coder", "reviewer", "documenter", "system_coordinator"]
      },
      "L1_expert": {
        "priority": 2,
        "can_spawn": ["L2_subagent"],
        "agents": ["gui-super-expert", "database_expert", "security_unified_expert", "mql_expert", "trading_strategy_expert", "tester_expert", "architect_expert", "integration_expert", "devops_expert", "languages_expert", "ai_integration_expert", "claude_systems_expert", "mobile_expert", "n8n_expert", "social_identity_expert"]
      },
      "L2_subagent": {
        "priority": 3,
        "can_spawn": [],
        "agents": ["gui-layout-specialist", "db-query-optimizer", "security-auth-specialist", "mql-optimization", "trading-risk-calculator", "test-unit-specialist", "architect-design-specialist", "api-endpoint-builder", "devops-pipeline-specialist", "languages-refactor-specialist", "ai-model-specialist", "claude-prompt-optimizer", "mobile-ui-specialist", "n8n-workflow-builder", "social-oauth-specialist"]
      }
    },
    "enforce_spawn_rules": true,
    "documenter_always_last": true
  },

  "execution_strategy": {
    "default": "parallel_with_dependencies",
    "strategies": {
      "parallel_with_dependencies": {
        "description": "Esegue task indipendenti in parallelo, rispetta dipendenze",
        "batch_independent": true,
        "wait_for_blocking": true
      },
      "sequential": {
        "description": "Esegue task uno alla volta in ordine",
        "use_when": "critical_path"
      },
      "aggressive_parallel": {
        "description": "Massimo parallelismo, minimo attesa",
        "max_concurrent": 64,
        "use_when": "batch_processing"
      }
    }
  },

  "rules_summary": {
    "rule_1": "Esecuzione parallela multi-agent (fino a 64 simultanei)",
    "rule_2": "Clear contesto prima di ogni agent",
    "rule_3": "Visualizzazione completa di tutte le attivita",
    "rule_4": "Error recovery con retry, escalation, fallback",
    "rule_5": "Token budget management con auto-decomposizione"
  }
}
