{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://orchestrator-plugin.dev/schemas/documentation-schema.json",
  "title": "Orchestrator Plugin Documentation Schema",
  "description": "JSON schema defining the structure and validation rules for all Orchestrator Plugin v4.1 EMPEROR documentation",
  "version": "4.1.0-EMPEROR",
  "schemaVersion": "1.0.0",

  "definitions": {

    "versionPattern": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(-([A-Z0-9]+))?$",
      "description": "Semantic version with optional codename suffix (e.g., 4.1.0-EMPEROR)",
      "examples": ["4.1.0-EMPEROR", "4.0.0", "5.0.0-EMPEROR-II"]
    },

    "iso8601Date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO 8601 date format (YYYY-MM-DD)",
      "examples": ["2026-02-01", "2026-12-31"]
    },

    "docStatus": {
      "type": "string",
      "enum": ["stable", "draft", "deprecated", "archived"],
      "description": "Document status"
    },

    "docCategory": {
      "type": "string",
      "enum": ["user", "developer", "ai", "release", "legacy", "official"],
      "description": "Document category determines location and audience"
    },

    "docAudience": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced", "any"],
      "description": "Target audience expertise level"
    },

    "priorityLevel": {
      "type": "string",
      "enum": ["CRITICA", "ALTA", "MEDIA", "BASSA"],
      "description": "Priority level for task execution"
    },

    "modelType": {
      "type": "string",
      "enum": ["haiku", "sonnet", "opus", "auto"],
      "description": "AI model type for task execution"
    },

    "taskStatus": {
      "type": "string",
      "enum": ["pending", "ready", "running", "completed", "failed", "cancelled", "escalated", "planning", "in_progress"],
      "description": "Task execution status"
    },

    "complexityLevel": {
      "type": "string",
      "enum": ["bassa", "media", "alta", "molto_alta", "low", "medium", "high", "critical"],
      "description": "Task or system complexity level"
    },

    "frontmatter": {
      "type": "object",
      "description": "YAML frontmatter metadata for documentation files",
      "required": ["title", "version", "last_updated", "status", "category"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 5,
          "maxLength": 100,
          "description": "Document title"
        },
        "version": { "$ref": "#/definitions/versionPattern" },
        "last_updated": { "$ref": "#/definitions/iso8601Date" },
        "status": { "$ref": "#/definitions/docStatus" },
        "category": { "$ref": "#/definitions/docCategory" },
        "audience": { "$ref": "#/definitions/docAudience" },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 2, "maxLength": 30 },
          "maxItems": 10,
          "uniqueItems": true,
          "description": "Searchable tags for the document"
        },
        "related": {
          "type": "array",
          "items": { "type": "string", "format": "uri-reference" },
          "maxItems": 10,
          "uniqueItems": true,
          "description": "Related document paths"
        },
        "authors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" }
            }
          },
          "maxItems": 5
        },
        "reviewers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "role": { "type": "string" }
            }
          },
          "maxItems": 5
        },
        "document_id": {
          "type": "string",
          "pattern": "^DOC-[A-Z0-9]{3}-\\d{3}$",
          "description": "Unique document identifier (e.g., DOC-MASTER-001)"
        },
        "next_review": { "$ref": "#/definitions/iso8601Date" },
        "estimated_reading_time": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300,
          "description": "Estimated reading time in minutes"
        },
        "requires_version": {
          "type": "string",
          "description": "Minimum plugin version required for this document"
        },
        "supersedes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Document IDs that this document supersedes"
        }
      }
    },

    "metadata": {
      "type": "object",
      "description": "Metadata for all document types",
      "required": ["id", "title", "version", "created", "updated"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^DOC-[A-Z0-9]{3}-\\d{3}$",
          "description": "Unique document identifier"
        },
        "title": { "type": "string", "minLength": 5, "maxLength": 200 },
        "version": { "$ref": "#/definitions/versionPattern" },
        "created": { "$ref": "#/definitions/iso8601Date" },
        "updated": { "$ref": "#/definitions/iso8601Date" },
        "status": { "$ref": "#/definitions/docStatus" },
        "category": { "$ref": "#/definitions/docCategory" },
        "path": {
          "type": "string",
          "format": "uri-reference",
          "description": "Relative path from docs/official/"
        }
      }
    },

    "crossReference": {
      "type": "object",
      "description": "Cross-reference format for linking between documents",
      "required": ["target", "type"],
      "properties": {
        "target": {
          "type": "string",
          "description": "Target document path or anchor"
        },
        "type": {
          "type": "string",
          "enum": ["internal", "external", "code", "section"],
          "description": "Reference type"
        },
        "label": {
          "type": "string",
          "description": "Display text for the link"
        },
        "anchor": {
          "type": "string",
          "description": "Section anchor within the target document"
        }
      }
    },

    "codeExample": {
      "type": "object",
      "description": "Structure for code examples in documentation",
      "required": ["language", "code"],
      "properties": {
        "language": {
          "type": "string",
          "enum": ["typescript", "javascript", "python", "bash", "json", "yaml", "markdown", "mermaid"],
          "description": "Programming language or format"
        },
        "code": {
          "type": "string",
          "description": "The code content"
        },
        "file": {
          "type": "string",
          "description": "Source file path if referencing actual code"
        },
        "lines": {
          "type": "string",
          "pattern": "^\\d+(-\\d+)?$",
          "description": "Line numbers referenced (e.g., '42' or '42-57')"
        },
        "caption": {
          "type": "string",
          "maxLength": 200,
          "description": "Optional caption for the code example"
        },
        "output": {
          "type": "string",
          "description": "Expected output when the code is executed"
        },
        "tested": {
          "type": "boolean",
          "description": "Whether the example has been tested"
        }
      }
    },

    "section": {
      "type": "object",
      "description": "Document section structure",
      "required": ["title", "content"],
      "properties": {
        "title": { "type": "string" },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6,
          "description": "Heading level (1-6)"
        },
        "anchor": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "URL-safe anchor for the section"
        },
        "content": {
          "type": "string",
          "description": "Section content in markdown"
        },
        "subsections": {
          "type": "array",
          "items": { "$ref": "#/definitions/section" }
        }
      }
    },

    "userDocument": {
      "type": "object",
      "description": "Schema for user-facing documentation",
      "allOf": [
        { "$ref": "#/definitions/metadata" },
        {
          "type": "object",
          "required": ["category", "audience"],
          "properties": {
            "category": { "const": "user" },
            "audience": {
              "type": "string",
              "enum": ["beginner", "intermediate", "advanced"]
            },
            "prerequisites": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Required knowledge before reading"
            },
            "learning_objectives": {
              "type": "array",
              "items": { "type": "string" },
              "maxItems": 10
            },
            "estimated_time": {
              "type": "integer",
              "description": "Estimated reading time in minutes"
            }
          }
        }
      ]
    },

    "developerDocument": {
      "type": "object",
      "description": "Schema for developer/contributor documentation",
      "allOf": [
        { "$ref": "#/definitions/metadata" },
        {
          "type": "object",
          "required": ["category"],
          "properties": {
            "category": { "const": "developer" },
            "api_version": { "type": "string" },
            "related_modules": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Related source code modules"
            },
            "complexity": { "$ref": "#/definitions/complexityLevel" }
          }
        }
      ]
    },

    "aiDocument": {
      "type": "object",
      "description": "Schema for AI system integration documentation",
      "allOf": [
        { "$ref": "#/definitions/metadata" },
        {
          "type": "object",
          "required": ["category"],
          "properties": {
            "category": { "const": "ai" },
            "protocol_version": { "type": "string" },
            "supported_models": {
              "type": "array",
              "items": { "$ref": "#/definitions/modelType" }
            },
            "mcp_compatible": {
              "type": "boolean",
              "description": "Whether compatible with MCP protocol"
            }
          }
        }
      ]
    },

    "releaseDocument": {
      "type": "object",
      "description": "Schema for release documentation",
      "allOf": [
        { "$ref": "#/definitions/metadata" },
        {
          "type": "object",
          "required": ["category", "release_version", "release_date"],
          "properties": {
            "category": { "const": "release" },
            "release_version": { "$ref": "#/definitions/versionPattern" },
            "release_date": { "$ref": "#/definitions/iso8601Date" },
            "support_until": { "$ref": "#/definitions/iso8601Date" },
            "codename": {
              "type": "string",
              "pattern": "^[A-Z0-9-]+$",
              "description": "Release codename (e.g., EMPEROR)"
            },
            "breaking_changes": {
              "type": "boolean",
              "description": "Whether this release has breaking changes"
            },
            "migration_required": {
              "type": "boolean",
              "description": "Whether migration from previous version is required"
            },
            "previous_version": {
              "type": "string",
              "description": "Previous version this release upgrades"
            }
          }
        }
      ]
    },

    "taskDefinition": {
      "type": "object",
      "description": "Task definition for orchestration",
      "required": ["id", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(task_|T)\\d+$",
          "description": "Task identifier (e.g., task_1, T1)"
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1000,
          "description": "Task description"
        },
        "agentFile": {
          "type": "string",
          "pattern": "^(core|experts)/[a-z_-]+\\.md$",
          "description": "Agent file path"
        },
        "model": { "$ref": "#/definitions/modelType" },
        "priority": { "$ref": "#/definitions/priorityLevel" },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Task IDs this task depends on"
        },
        "timeout": {
          "type": "integer",
          "minimum": 1000,
          "description": "Task timeout in milliseconds"
        },
        "retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "description": "Number of retry attempts"
        },
        "estimatedTime": {
          "type": "integer",
          "minimum": 1,
          "description": "Estimated execution time in minutes"
        },
        "estimatedCost": {
          "type": "number",
          "minimum": 0,
          "description": "Estimated cost in USD"
        }
      }
    },

    "agentDefinition": {
      "type": "object",
      "description": "Expert agent definition",
      "required": ["id", "name", "file", "model", "specialization"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique agent identifier"
        },
        "name": {
          "type": "string",
          "minLength": 3,
          "maxLength": 50
        },
        "file": {
          "type": "string",
          "pattern": "^(core|experts)/[a-z_-]+\\.md$",
          "description": "Path to agent definition file"
        },
        "model": { "$ref": "#/definitions/modelType" },
        "priority": { "$ref": "#/definitions/priorityLevel" },
        "specialization": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "maxItems": 20,
          "description": "Agent specializations/domains"
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Keywords that trigger this agent"
        },
        "level": {
          "type": "integer",
          "enum": [1, 2, 3],
          "description": "Agent level: 1=Core, 2=Specialist, 3=Micro"
        },
        "description": {
          "type": "string",
          "maxLength": 500
        },
        "size_kb": {
          "type": "number",
          "description": "Agent file size in KB"
        },
        "version": {
          "type": "string",
          "description": "Agent definition version"
        }
      }
    },

    "changelogEntry": {
      "type": "object",
      "description": "Single changelog entry",
      "required": ["version", "date", "changes"],
      "properties": {
        "version": { "$ref": "#/definitions/versionPattern" },
        "date": { "$ref": "#/definitions/iso8601Date" },
        "codename": {
          "type": "string",
          "pattern": "^[A-Z0-9-]+$"
        },
        "changes": {
          "type": "object",
          "properties": {
            "added": {
              "type": "array",
              "items": { "type": "string" }
            },
            "changed": {
              "type": "array",
              "items": { "type": "string" }
            },
            "deprecated": {
              "type": "array",
              "items": { "type": "string" }
            },
            "removed": {
              "type": "array",
              "items": { "type": "string" }
            },
            "fixed": {
              "type": "array",
              "items": { "type": "string" }
            },
            "security": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },

    "configurationSchema": {
      "type": "object",
      "description": "Configuration options schema",
      "properties": {
        "maxConcurrent": {
          "type": "integer",
          "minimum": 1,
          "maximum": 128,
          "default": 12,
          "description": "Maximum concurrent agents"
        },
        "maxDepth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "default": 10,
          "description": "Maximum task dependency depth"
        },
        "maxTasks": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000,
          "default": 500,
          "description": "Maximum tasks per session"
        },
        "taskTimeout": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 3600000,
          "default": 300000,
          "description": "Task timeout in milliseconds"
        },
        "enableSmartModelSelection": {
          "type": "boolean",
          "default": true
        },
        "enableAgentDiscovery": {
          "type": "boolean",
          "default": true
        },
        "enableAutoDocumentation": {
          "type": "boolean",
          "default": true
        },
        "enableCleanContext": {
          "type": "boolean",
          "default": true,
          "description": "Enable Clean Context mode for token optimization"
        },
        "simulateExecution": {
          "type": "boolean",
          "default": true,
          "description": "Simulate execution without real agent calls"
        },
        "defaultModel": { "$ref": "#/definitions/modelType" },
        "logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info"
        }
      }
    },

    "documentationIndex": {
      "type": "object",
      "description": "Master documentation index structure",
      "required": ["version", "last_updated", "documents"],
      "properties": {
        "version": { "$ref": "#/definitions/versionPattern" },
        "last_updated": { "$ref": "#/definitions/iso8601Date" },
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "documents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "path", "category"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^DOC-[A-Z0-9]{3}-\\d{3}$"
              },
              "path": {
                "type": "string",
                "format": "uri-reference"
              },
              "title": { "type": "string" },
              "category": { "$ref": "#/definitions/docCategory" },
              "status": { "$ref": "#/definitions/docStatus" },
              "version": { "$ref": "#/definitions/versionPattern" }
            }
          }
        }
      }
    }
  },

  "type": "object",
  "required": ["schemaInfo"],
  "properties": {
    "schemaInfo": {
      "type": "object",
      "required": ["name", "version", "created", "description"],
      "properties": {
        "name": {
          "type": "string",
          "const": "Orchestrator Plugin Documentation Schema"
        },
        "version": {
          "type": "string",
          "const": "1.0.0"
        },
        "created": { "$ref": "#/definitions/iso8601Date" },
        "description": {
          "type": "string",
          "const": "Master schema for Orchestrator Plugin v4.1 EMPEROR documentation validation"
        },
        "plugin_version": {
          "type": "string",
          "const": "4.1.0-EMPEROR"
        }
      }
    },

    "versionStrategy": {
      "type": "object",
      "description": "Version notation and strategy rules",
      "required": ["format", "current", "support_policy"],
      "properties": {
        "format": {
          "type": "string",
          "const": "MAJOR.MINOR.PATCH-CODENAME",
          "description": "Version format with semantic versioning and codename"
        },
        "current": {
          "type": "string",
          "const": "4.1.0-EMPEROR"
        },
        "codename_series": {
          "type": "string",
          "const": "EMPEROR"
        },
        "support_policy": {
          "type": "object",
          "properties": {
            "major_support_months": {
              "type": "integer",
              "const": 12
            },
            "minor_support_months": {
              "type": "integer",
              "const": 6
            },
            "patch_support_months": {
              "type": "integer",
              "const": 3
            },
            "deprecation_notice_months": {
              "type": "integer",
              "const": 3
            }
          }
        }
      }
    },

    "crossReferenceFormat": {
      "type": "object",
      "description": "Cross-referencing format standards",
      "properties": {
        "internal_link": {
          "type": "string",
          "pattern": "^\\[([^\\]]+)\\]\\(([^)]+)(#([^)]+))?\\)$",
          "description": "Markdown internal link format with optional anchor"
        },
        "code_reference": {
          "type": "string",
          "pattern": "^`([a-z_/-]+\\.(ts|js|py|md))`(:(\\d+))?(:\\d+)?$",
          "description": "Code file reference with optional line numbers"
        },
        "api_reference": {
          "type": "string",
          "pattern": "^([A-Z][a-zA-Z0-9]*)\\.([a-z][a-zA-Z0-9]*)\\(\\)$",
          "description": "API function reference (e.g., Orchestrator.execute())"
        }
      }
    },

    "documentTypes": {
      "type": "object",
      "description": "Document type definitions and their required sections",
      "properties": {
        "user_guide": {
          "type": "object",
          "properties": {
            "required_sections": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["Overview", "Getting Started", "Usage", "Examples", "FAQ", "Troubleshooting"]
              }
            },
            "optional_sections": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["Prerequisites", "Configuration", "Advanced Usage", "Best Practices"]
              }
            }
          }
        },
        "api_reference": {
          "type": "object",
          "properties": {
            "required_sections": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["Overview", "Classes", "Interfaces", "Functions", "Types", "Examples"]
              }
            },
            "per_item": {
              "type": "object",
              "properties": {
                "signature": { "type": "boolean" },
                "description": { "type": "boolean" },
                "parameters": { "type": "boolean" },
                "returns": { "type": "boolean" },
                "throws": { "type": "boolean" },
                "example": { "type": "boolean" },
                "see_also": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          }
        },
        "architecture_doc": {
          "type": "object",
          "properties": {
            "required_sections": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["Overview", "Architecture", "Components", "Data Flow", "Design Decisions"]
              }
            },
            "required_diagrams": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["High-Level Architecture", "Component Diagram", "Data Flow", "Sequence Diagram"]
              }
            }
          }
        },
        "release_notes": {
          "type": "object",
          "properties": {
            "required_sections": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["Overview", "What's New", "Breaking Changes", "Migration Guide", "Known Issues"]
              }
            },
            "change_categories": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["Added", "Changed", "Deprecated", "Removed", "Fixed", "Security"]
              }
            }
          }
        }
      }
    },

    "metadataFormat": {
      "type": "object",
      "description": "Metadata format for all documentation files",
      "allOf": [{ "$ref": "#/definitions/frontmatter" }]
    },

    "validationRules": {
      "type": "object",
      "description": "Additional validation rules beyond JSON schema",
      "properties": {
        "max_nesting_level": {
          "type": "integer",
          "default": 6,
          "description": "Maximum heading nesting level"
        },
        "max_code_block_length": {
          "type": "integer",
          "default": 100,
          "description": "Maximum lines per code block"
        },
        "max_paragraph_length": {
          "type": "integer",
          "default": 500,
          "description": "Maximum characters per paragraph"
        },
        "require_code_examples": {
          "type": "boolean",
          "default": true,
          "description": "Whether code examples are required for technical docs"
        },
        "require_table_of_contents": {
          "type": "boolean",
          "default": true,
          "description": "Whether table of contents is required"
        },
        "link_validation": {
          "type": "object",
          "properties": {
            "check_internal": { "type": "boolean", "default": true },
            "check_external": { "type": "boolean", "default": true },
            "check_anchors": { "type": "boolean", "default": true },
            "allow_anchors": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
