        "description": "Escalate if task takes longer than expected"
      },
      "error_patterns": {
        "enabled": true,
        "patterns": [
          "insufficient context",
          "requires deeper analysis",
          "complex reasoning needed",
          "architectural thinking required"
        ]
      }
    },
    "escalation_cooldown": 300,
    "max_escalations_per_session": 5
  },
  "cost_optimization": {
    "prefer_cheaper_models": true,
    "budget_alerts": {
      "enabled": true,
      "thresholds": [0.5, 1.0, 2.0, 5.0]
    },
    "auto_downgrade": {
      "enabled": false,
      "description": "Automatically use cheaper model if task allows"
    },
    "batch_optimization": {
