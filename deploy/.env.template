# =============================================================================
# CCA/CCG Dual System - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# API KEYS (Required - choose based on your profile)
# -----------------------------------------------------------------------------

# CCA Profile - Anthropic Claude Opus 4.6
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# CCG Profile - GLM5 via Z.AI
# Get your key at: https://zukijourney.com/
# ZAI_API_KEY=zai-your-key-here

# Alternative CCG configuration (if using direct endpoint)
# ANTHROPIC_AUTH_TOKEN=zai-your-key-here
# ANTHROPIC_BASE_URL=https://api.zukijourney.com/v1

# -----------------------------------------------------------------------------
# GITHUB INTEGRATION (Optional)
# -----------------------------------------------------------------------------

# GitHub Personal Access Token
# Required scopes: repo, read:org, read:user
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp-your-token-here

# -----------------------------------------------------------------------------
# SYSTEM PATHS (Auto-configured)
# -----------------------------------------------------------------------------

# Claude home directory
CLAUDE_HOME=/path/to/.claude

# Active profile: cca or ccg
CLAUDE_PROFILE=cca

# -----------------------------------------------------------------------------
# PYTHON CONFIGURATION (Optional)
# -----------------------------------------------------------------------------

# Force UTF-8 encoding
PYTHONIOENCODING=utf-8

# Python path (if non-standard)
# PYTHON_PATH=/usr/bin/python3

# -----------------------------------------------------------------------------
# MCP SERVERS (Optional - Advanced)
# -----------------------------------------------------------------------------

# Orchestrator MCP is auto-configured
# Add additional MCP servers here if needed

# Example: Filesystem MCP
# MCP_FILESYSTEM_ROOT=/path/to/allowed/directory

# Example: Custom MCP endpoint
# MCP_CUSTOM_ENDPOINT=https://your-mcp-server.com

# -----------------------------------------------------------------------------
# LOGGING (Optional)
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR
# CLAUDE_LOG_LEVEL=INFO

# Enable debug mode
# CLAUDE_DEBUG=false

# -----------------------------------------------------------------------------
# PERFORMANCE (Optional)
# -----------------------------------------------------------------------------

# Max concurrent agent tasks
# CLAUDE_MAX_CONCURRENT=5

# Task timeout in seconds
# CLAUDE_TASK_TIMEOUT=300

# Cache TTL in seconds
# CLAUDE_CACHE_TTL=3600

# =============================================================================
# END OF TEMPLATE
# =============================================================================
